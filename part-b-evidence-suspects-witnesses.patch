      evidence_id: `e${Date.now()}`,
      case_id: caseId,
      uploaded_by: officerName,
      file_name: fileName.trim(),
      file_type: fileType,
      description: description.trim(),
      custody_notes: custodyNotes.trim(),
      uploaded_at: now,
    })

    addNotification({
      notification_id: `n${Date.now()}`,
      message: `Evidence "${fileName.trim()}" added to case`,
      type: 'Evidence Added',
      related_case_number: caseId,
      is_read: false,
      created_at: now,
    })

    setFileName('')
    setFileType('Document')
    setDescription('')
    setCustodyNotes('')
    setShowForm(false)
  }

  const FILE_TYPES: Evidence['file_type'][] = ['Image', 'Video', 'Document', 'Audio']

  return (
