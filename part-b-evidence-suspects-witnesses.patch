            ({evidenceList.length})
          </span>
        </h2>
        {canEdit && !showForm && (
          <Button size="sm" onClick={() => setShowForm(true)}>
            Add Evidence
          </Button>
        )}
      </div>

      {canEdit && showForm && (
        <div className="mb-6 p-4 border rounded-lg bg-muted/30 space-y-4">
          <h3 className="text-sm font-semibold">New Evidence Item</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <Label htmlFor="ev-filename">File / Item Name</Label>
              <Input
                id="ev-filename"
                className="mt-1"
                placeholder="e.g. cctv_clip_01.mp4"
