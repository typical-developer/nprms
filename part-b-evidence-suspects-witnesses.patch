            </div>
            <div>
              <Label htmlFor="ev-filetype">Type</Label>
              <Select value={fileType} onValueChange={(v) => setFileType(v as Evidence['file_type'])}>
                <SelectTrigger id="ev-filetype" className="mt-1">
