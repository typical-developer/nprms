                </SelectTrigger>
                <SelectContent>
                  {FILE_TYPES.map((t) => (
                    <SelectItem key={t} value={t}>{t}</SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div className="md:col-span-2">
              <Label htmlFor="ev-desc">Description</Label>
              <Textarea
                id="ev-desc"
                className="mt-1"
                placeholder="Describe what this evidence shows or proves..."
                value={description}
                onChange={(e) => setDescription(e.target.value)}
              />
            </div>
            <div className="md:col-span-2">
              <Label htmlFor="ev-custody">Custody Notes</Label>
              <Input
                id="ev-custody"
                className="mt-1"
                placeholder="Where is the physical item stored?"
                value={custodyNotes}
                onChange={(e) => setCustodyNotes(e.target.value)}
              />
            </div>
          </div>
          <div className="flex gap-2">
            <Button onClick={handleSubmit} disabled={!fileName.trim() || !description.trim()}>
              Save Evidence
